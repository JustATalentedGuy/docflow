AWS_REGION=us-east-1
S3_BUCKET_NAME=docflow-demo-yourname

# Leave blank on EC2/ECS when the instance/task role has S3 permissions.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT_URL=

REDIS_URL=redis://redis:6379/0
POSTGRES_DB=docflow
POSTGRES_USER=docflow_user
POSTGRES_PASSWORD=CHANGE_ME_USE_A_LONG_RANDOM_PASSWORD
DATABASE_URL=postgresql://docflow_user:CHANGE_ME_USE_A_LONG_RANDOM_PASSWORD@postgres:5432/docflow
SESSION_TTL_HOURS=168

QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=docflow_chunks

GROQ_API_KEY=CHANGE_ME
GROQ_MODEL=llama-3.1-8b-instant

HF_API_TOKEN=CHANGE_ME
HF_CAPTIONING_MODEL=Salesforce/blip-image-captioning-large
ENABLE_IMAGE_CAPTIONING=false

LANGCHAIN_API_KEY=CHANGE_ME
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=docflow-aws-demo

EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
EMBEDDING_BATCH_SIZE=8

LOG_LEVEL=INFO
MAX_FILE_SIZE_MB=50

PARENT_CHUNK_SIZE=1500
PARENT_CHUNK_OVERLAP=200
CHILD_CHUNK_SIZE=300
CHILD_CHUNK_OVERLAP=50
