# Docflow local development environment
#
# Copy this file to .env before starting Docker Compose:
#   Windows PowerShell: Copy-Item .env.example .env
#   Linux/macOS:        cp .env.example .env
#
# Never commit the copied .env file. The values below are local defaults and
# placeholders only. See CLOUD-SETUP-GUIDE.md for AWS configuration.

# Local MinIO (S3-compatible storage)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
S3_BUCKET_NAME=docflow-uploads
AWS_ENDPOINT_URL=http://minio:9000

# Redis and database
REDIS_URL=redis://redis:6379/0
DATABASE_URL=sqlite:///data/docflow.db
SESSION_TTL_HOURS=168

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=docflow_chunks

# Groq language model
# Create a key at https://console.groq.com
GROQ_API_KEY=CHANGE_ME
GROQ_MODEL=llama-3.1-8b-instant

# Optional image captioning
# Create a read token at https://huggingface.co/settings/tokens
HF_API_TOKEN=CHANGE_ME
HF_CAPTIONING_MODEL=Salesforce/blip-image-captioning-large
ENABLE_IMAGE_CAPTIONING=false

# Optional LangSmith tracing
# Create a key at https://smith.langchain.com
LANGCHAIN_API_KEY=CHANGE_ME
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=docflow

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
EMBEDDING_BATCH_SIZE=8

# Application
LOG_LEVEL=INFO
MAX_FILE_SIZE_MB=50

# Document chunking
PARENT_CHUNK_SIZE=1500
PARENT_CHUNK_OVERLAP=200
CHILD_CHUNK_SIZE=300
CHILD_CHUNK_OVERLAP=50
