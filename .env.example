# ══════════════════════════════════════════════════════════════════════════════
# Docflow environment configuration
#
# LOCAL SETUP (Docker Compose + MinIO):
#   1. Copy this file to .env
#   2. Set GROQ_API_KEY, HF_API_TOKEN, LANGCHAIN_API_KEY (see links below)
#   3. All other values work as-is for local Docker Compose
#
# CLOUD SETUP (AWS EC2 + S3):
#   - Remove AWS_ENDPOINT_URL (or leave it empty)
#   - Set real AWS credentials and region
#   - Create the S3 bucket manually before first run
#
# Key registration (all free, no credit card):
#   Groq:       https://console.groq.com            → API Keys → Create
#   HF Token:   https://huggingface.co/settings/tokens → New token → Read
#   LangSmith:  https://smith.langchain.com          → Settings → API Keys
# ══════════════════════════════════════════════════════════════════════════════

# ── AWS / MinIO ───────────────────────────────────────────────────────────────
# For local MinIO, keep these as minioadmin / minioadmin
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
S3_BUCKET_NAME=docflow-uploads
# Set this for local MinIO. Remove or leave empty for real AWS S3.
AWS_ENDPOINT_URL=http://minio:9000

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=docflow_chunks

# ── Groq ─────────────────────────────────────────────────────────────────────
# ★ CHANGE THIS — get free key at https://console.groq.com
GROQ_API_KEY=CHANGE_ME
GROQ_MODEL=llama-3.1-8b-instant

# ── Hugging Face (image captioning) ──────────────────────────────────────────
# ★ CHANGE THIS — get free token at https://huggingface.co/settings/tokens
HF_API_TOKEN=CHANGE_ME
HF_CAPTIONING_MODEL=Salesforce/blip-image-captioning-large

# ── LangSmith (agent tracing) ────────────────────────────────────────────────
# ★ CHANGE THIS — get free key at https://smith.langchain.com
LANGCHAIN_API_KEY=CHANGE_ME
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=docflow

# ── Embedding ─────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ── Application ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
MAX_FILE_SIZE_MB=50
DATABASE_URL=sqlite:///data/docflow.db
SESSION_TTL_HOURS=168

# ── Chunking ──────────────────────────────────────────────────────────────────
PARENT_CHUNK_SIZE=1500
PARENT_CHUNK_OVERLAP=200
CHILD_CHUNK_SIZE=300
CHILD_CHUNK_OVERLAP=50
